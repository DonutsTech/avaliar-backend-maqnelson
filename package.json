{
  "name": "maqnelson-backend",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
     "dev": "tsx watch src/server.ts",
    "db:deploy": "yarn prisma migrate deploy && yarn prisma generate",
    "db:push": "yarn prisma db push && yarn prisma generate",
    "dev:full": "yarn run db:push && yarn run dev",
    "lint": "eslint src/**/*.{js,ts} --fix",
    "lint:check": "eslint src/**/*.{js,ts}",
    "format": "prettier --write src/**/*.{js,ts,json}",
    "build": "tsc",
    "start": "node dist/server.js",
    "prod": "pm2 start ecosystem.config.cjs"
  },
  "type": "module",
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.16.0",
    "eslint": "^10.0.1",
    "prisma": "^7.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@aws-sdk/lib-storage": "^3.1071.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@types/express": "^5.0.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.18.0",
    "uuid": "^13.0.0"
  }
}
