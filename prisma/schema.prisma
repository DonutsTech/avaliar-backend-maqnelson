// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  ID        String   @id @default(uuid()) @db.Uuid
  ROLE      String   @default("USER")
  EMAIL     String   @unique
  PASSWORD  String
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt

  @@map("user")
}

model Checkin {
  ID        String   @id @default(uuid()) @db.Uuid
  NAME      String
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  SCHEMAS Schema[]

  @@map("checkin")
}

model Schema {
  ID        String  @id @default(uuid()) @db.Uuid
  TITLE     String
  CHECKIN   Checkin @relation(fields: [IDCHECKIN], references: [ID])
  IDCHECKIN String  @db.Uuid
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  MODELS   Model[]

  @@map("schema")
}

model Model {
  ID            String  @id @default(uuid()) @db.Uuid
  NAME          String
  TITLE         String
  QUESTION      String
  SCHEMA        Schema  @relation(fields: [IDSCHEMA], references: [ID])
  IDSCHEMA      String  @db.Uuid
  CREATEDAT     DateTime @default(now())
  UPDATEDAT     DateTime @updatedAt
  INPUTS        Input[]

  @@map("model")
}

model Input {
  ID          String  @id @default(uuid()) @db.Uuid
  TYPE        String
  NAME        String
  LABEL       String
  PLACEHOLDER String?
  VALUE       String @default("")
  MIN         Int?
  MAX         Int?
  REQUIRED    Boolean @default(false)
  MULTIPLE    Boolean @default(false)
  BONDTYPE    String @default("")
  MODEL       Model  @relation(fields: [IDMODEL], references: [ID])
  IDMODEL     String  @db.Uuid
  CREATEDAT   DateTime @default(now())
  UPDATEDAT   DateTime @updatedAt
  EMUNS       Emun[]

  @@map("input")
}

model Emun {
  ID        String  @id @default(uuid()) @db.Uuid
  NAME      String
  TITLE     String
  INPUT     Input  @relation(fields: [IDINPUT], references: [ID])
  IDINPUT   String  @db.Uuid
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt

  @@map("enum")
}

model VersionCheckin {
  ID        String   @id @default(uuid()) @db.Uuid
  IDCHECKIN String   @db.Uuid
  NAME      String
  VERSION   Int
  JSON_CHECKIN String
  OBJECT_CHECKIN String
  VIDEO Boolean @default(false)
  PHOTO Boolean @default(false)
  ATIVE    Boolean  @default(true)
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  RATES  Rate[]

  @@map("version_checkin")
}

model Rate {
  ID        Int   @id @default(autoincrement())
  UUIDAPP      String @unique
  IDVERSIONCHECKIN String? @db.Uuid
  VERSIONCHECKIN VersionCheckin? @relation(fields: [IDVERSIONCHECKIN], references: [ID])
  RESULT String? @default("")
  STATUS String @default("EM ANDAMENTO")
  MESSAGE String? @default("")
  TYPE String? @default("")
  MARK String? @default("")
  MODEL String? @default("")
  CHASSI String? @default("")
  VALUE String? @default("")
  CODVEND String? @default("")
  FILIAL String? @default("")
  NAMEVEND String? @default("")
  EMAILVEND String? @default("")
  CODCLI String? @default("")
  LJCLI String? @default("")
  CODPROS String? @default("")
  LJPROS String? @default("")
  NAMECLI String? @default("")
  ADDRESSCLI String? @default("")
  PHONECLI String? @default("")
  EMAILCLI String? @default("")
  DATE String? @default("")
  PHOTO String? @default("")
  VALUE1YEAR String? @default("")
  VALUE2YEAR String? @default("")
  VALUE3YEAR String? @default("")
  VALUE4YEAR String? @default("")
  TAXA String? @default("")
  VALUEVIEW String? @default("")
  VALUERATE String? @default("")
  VALIDITY String? @default("")
  VALUESUG String? @default("")
  FILIAL_WEB String? @default("")
  CANAL String? @default("")
  RESSED Boolean? @default(false)
  MODALITY String? @default("")
  VALUEBY String? @default("")
  VALUENEG String? @default("")
  STOKE Boolean? @default(false)
  REASON Boolean? @default(false)
  OBSREASON String? @default("")
  INDICATOR Boolean? @default(false)
  WHO String? @default("")
  OBSALL String? @default("")
  SYNC Boolean @default(false)
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  GALERYRATES GaleryRate[] @relation("RateGaleryByUuid")

  @@map("rate")
}

model MarkWheels {
  ID        Int      @id @default(autoincrement())
  UUIDAPP   String   @unique
  NAME      String   @unique
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt

  @@map("markwheels")
}

model GaleryRate {
  ID          Int       @id @default(autoincrement())
  UUIDAPP     String    @unique
  NAME        String
  URL         String
  RATE_UUIDAPP String
  RATE Rate @relation("RateGaleryByUuid", fields: [RATE_UUIDAPP], references: [UUIDAPP], onDelete: Cascade)
  CREATEDAT   DateTime  @default(now())
  UPDATEDAT   DateTime  @updatedAt

  @@map("galeryrate")
}
