// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  ID        String   @id @default(uuid()) @db.Uuid
  ROLE      String   @default("USER")
  EMAIL     String   @unique
  PASSWORD  String
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt

  @@map("user")
}

model Checkin {
  ID        String   @id @default(uuid()) @db.Uuid
  NAME      String
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  SCHEMAS Schema[]

  @@map("checkin")
}

model Schema {
  ID        String  @id @default(uuid()) @db.Uuid
  TITLE     String
  CHECKIN   Checkin @relation(fields: [IDCHECKIN], references: [ID])
  IDCHECKIN String  @db.Uuid
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  MODELS   Model[]

  @@map("schema")
}

model Model {
  ID            String  @id @default(uuid()) @db.Uuid
  NAME          String
  TITLE         String
  QUESTION      String
  SCHEMA        Schema  @relation(fields: [IDSCHEMA], references: [ID])
  IDSCHEMA      String  @db.Uuid
  CREATEDAT     DateTime @default(now())
  UPDATEDAT     DateTime @updatedAt
  INPUTS        Input[]

  @@map("model")
}

model Input {
  ID          String  @id @default(uuid()) @db.Uuid
  TYPE        String
  NAME        String
  LABEL       String
  PLACEHOLDER String?
  VALUE       String @default("")
  MIN         Int?
  MAX         Int?
  REQUIRED    Boolean @default(false)
  MULTIPLE    Boolean @default(false)
  BONDTYPE    String @default("")
  MODEL       Model  @relation(fields: [IDMODEL], references: [ID])
  IDMODEL     String  @db.Uuid
  CREATEDAT   DateTime @default(now())
  UPDATEDAT   DateTime @updatedAt
  EMUNS       Emun[]

  @@map("input")
}

model Emun {
  ID        String  @id @default(uuid()) @db.Uuid
  NAME      String
  TITLE     String
  INPUT     Input  @relation(fields: [IDINPUT], references: [ID])
  IDINPUT   String  @db.Uuid
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt

  @@map("enum")
}

model VersionCheckin {
  ID        String   @id @default(uuid()) @db.Uuid
  IDCHECKIN String   @db.Uuid
  NAME      String
  VERSION   Int
  JSON_CHECKIN String
  OBJECT_CHECKIN String
  VIDEO Boolean @default(false)
  PHOTO String @default("")
  ATIVE    Boolean  @default(true)
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  AVALIARS  Avaliar[]

  @@map("checkin_avaliar")
}

model Avaliar {
  ID        String   @id @default(uuid()) @db.Uuid
  IDVERSIONCHECKIN String   @db.Uuid
  VERSIONCHECKIN VersionCheckin @relation(fields: [IDVERSIONCHECKIN], references: [ID])
  RESULT String
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt
  STATUS String
  CODVEND String
  EMAILVEND String
  CODCLI String
  LJCLI String
  CODPROS String
  LJPROS String
  PHOTOS   PHOTO[]   // Add this line to define the opposite relation

  @@map("avaliar")
}

model PHOTO {
  ID        String   @id @default(uuid()) @db.Uuid
  URL       String
  TITLE     String
  IDAVALIAR String   @db.Uuid
  AVALIAR   Avaliar @relation(fields: [IDAVALIAR], references: [ID])
  CREATEDAT DateTime @default(now())
  UPDATEDAT DateTime @updatedAt

  @@map("photo")
}
