{
  // Formatação automática
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "vscode.typescript-language-features",

  // Ações automáticas ao salvar
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit",
    "source.removeUnusedImports": "explicit"
  },

  // Configurações do ESLint
  "eslint.probe": ["javascript", "typescript"],
  "eslint.format.enable": true,
  "eslint.lintTask.enable": true,
  "eslint.validate": ["typescript"],
  "eslint.workingDirectories": [{ "mode": "auto" }],

  // Configurações específicas para TypeScript
  "typescript.preferences.organizeImportsIgnoreCase": "auto",
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",

  // Auto-save para acionar as correções automaticamente
  "files.autoSave": "onFocusChange",

  // Configurações do editor
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.trimAutoWhitespace": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
